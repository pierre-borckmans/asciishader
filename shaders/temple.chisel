// Temple with pillars
pillar(h = 6) = {
  cylinder(0.3, h)
  sphere(0.4).at(0, h / 4, 0)
  box(1.2, 0.3, 1.2).at(0, -h / 4, 0)
}

base = box(16, 0.6, 10).at(0, -1.65, 0)
roof = box(14, 0.6, 12).at(0, 1.65, 0)

pillars = for i in 0..4 {
  pillar().at(-3 + i * 2, 0, -2) |
  pillar().at(-3 + i * 2, 0, 2)
}

base | pillars | roof
