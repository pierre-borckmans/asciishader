{
  "name": "Chisel",
  "scopeName": "source.chisel",
  "fileTypes": ["chisel"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#keyword" },
    { "include": "#setting" },
    { "include": "#shape" },
    { "include": "#builtin-function" },
    { "include": "#named-color" },
    { "include": "#constant" },
    { "include": "#builtin-var" },
    { "include": "#operator" },
    { "include": "#number" },
    { "include": "#hex-color" },
    { "include": "#string" },
    { "include": "#method" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        { "match": "//.*$", "name": "comment.line.double-slash.chisel" },
        { "begin": "/\\*", "end": "\\*/", "name": "comment.block.chisel" }
      ]
    },
    "keyword": {
      "match": "\\b(for|in|if|else|step|glsl)\\b",
      "name": "keyword.control.chisel"
    },
    "setting": {
      "match": "\\b(light|camera|bg|raymarch|post|debug|mat)\\b",
      "name": "keyword.other.chisel"
    },
    "shape": {
      "match": "\\b(sphere|box|cylinder|torus|capsule|cone|plane|octahedron|pyramid|ellipsoid|circle|rect|hexagon|polygon|rounded_box|wireframe_box|rounded_cylinder|capped_cylinder|capped_cone|rounded_cone)\\b",
      "name": "support.function.shape.chisel"
    },
    "builtin-function": {
      "match": "\\b(sin|cos|tan|asin|acos|atan|atan2|pow|sqrt|exp|log|floor|ceil|round|fract|abs|sign|min|max|mix|smoothstep|step|clamp|length|normalize|dot|cross|distance|reflect|mod|noise|fbm|voronoi|rgb|hsl|hsla|rgba|ease_in|ease_out|ease_in_out|ease_cubic_in|ease_cubic_out|ease_cubic_in_out|ease_elastic|ease_bounce|ease_back|ease_expo|pulse|saw|tri|remap|saturate|spring|keyframes)\\b",
      "name": "support.function.builtin.chisel"
    },
    "named-color": {
      "match": "\\b(red|green|blue|white|black|yellow|cyan|magenta|gray|orange|purple|pink)\\b",
      "name": "constant.language.color.chisel"
    },
    "constant": {
      "match": "\\b(PI|TAU|E|true|false)\\b",
      "name": "constant.language.chisel"
    },
    "builtin-var": {
      "match": "(?<![.a-zA-Z_])\\b(t|p|x|y|z)\\b",
      "name": "variable.language.chisel"
    },
    "operator": {
      "patterns": [
        { "match": "\\|[~/]", "name": "keyword.operator.boolean.smooth.chisel" },
        { "match": "-[~/]", "name": "keyword.operator.boolean.smooth.chisel" },
        { "match": "&[~/]", "name": "keyword.operator.boolean.smooth.chisel" },
        { "match": "[|&]", "name": "keyword.operator.boolean.chisel" },
        { "match": "==|!=|<=|>=|<|>", "name": "keyword.operator.comparison.chisel" },
        { "match": "->", "name": "keyword.operator.arrow.chisel" },
        { "match": "\\.\\.", "name": "keyword.operator.range.chisel" }
      ]
    },
    "number": {
      "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b",
      "name": "constant.numeric.chisel"
    },
    "hex-color": {
      "match": "#[0-9a-fA-F]{3,8}\\b",
      "name": "constant.other.color.chisel"
    },
    "string": {
      "patterns": [
        { "begin": "\"", "end": "\"", "name": "string.quoted.double.chisel" },
        { "begin": "'", "end": "'", "name": "string.quoted.single.chisel" }
      ]
    },
    "method": {
      "match": "(?<=\\.)(at|scale|rot|orient|mirror|rep|array|morph|shell|onion|displace|dilate|erode|round|elongate|twist|bend|color|metallic|roughness|emission|opacity|extrude|extrude_to|revolve)\\b",
      "name": "entity.name.function.method.chisel"
    },
    "punctuation": {
      "patterns": [
        { "match": "[()\\[\\]{}]", "name": "punctuation.bracket.chisel" },
        { "match": "[.,:]", "name": "punctuation.delimiter.chisel" }
      ]
    }
  }
}
